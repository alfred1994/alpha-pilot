# 长桥 OpenAPI 行情配置
LONGPORT_APP_KEY=
LONGPORT_APP_SECRET=
LONGPORT_ACCESS_TOKEN=
LONGPORT_OAUTH_TOKEN_PATH=~/.longbridge/openapi/tokens/default

# MiMo LLM
XIAOMI_API_KEY=
XIAOMI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# OpenRouter 舆情分析备用
OPENROUTER_API_KEY=

# 华泰证券 Skill
HT_APIKEY=

# Telegram 通知
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 交易通道: paper=模拟盘。real 目前只是预留适配器，不会启用真实交易。
BROKER_MODE=paper

# 快链路是否启用 LLM 决策
USE_LLM_IN_FAST=1

# 自动盯盘参数
AUTO_LOOP_INTERVAL=60
AUTO_SCAN_INTERVAL=1800
AUTO_STOP_INTERVAL=60
AUTO_REVIEW_AFTER=15:05
AUTO_NOTIFY_ENABLED=1
